# 复制为 .env
RABBITMQ_URL=amqp://mgp:mgp@localhost:5672/
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mgp
MINIO_SECRET_KEY=mgpsecret
MINIO_BUCKET=audio
MINIO_SECURE=false

TASK_QUEUE=gen.tasks
PROGRESS_CHANNEL=task.progress

# 启动时加载的模型（4090 可用 medium/large）
DEFAULT_MODEL=musicgen-medium
# 缺 GPU 时设 true，引擎走假实现，方便先调通链路
MOCK_ENGINE=false

# 响度归一化
NORMALIZE_LOUDNESS=true
TARGET_LUFS=-14.0

# 失败重试最大次数
MAX_RETRIES=2
